# ─────────────────────────────────────────────────────────────
# LuxeJewels environment variables
# Copy to `.env` and fill in. Every value is OPTIONAL — the app
# runs with local mock data when a service is not configured.
# ─────────────────────────────────────────────────────────────

# App
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# Database (Prisma / Postgres) — REQUIRED for persistence (users, orders, etc.)
# Neon, Supabase, Railway or a local Postgres all work. After setting this run:
#   npm run prisma:generate && npm run prisma:push && npm run prisma:seed
DATABASE_URL="postgresql://user:password@localhost:5432/luxejewels"

# Auth (Firebase) — passwordless OTP: phone SMS + email magic-link.
# These are the PUBLIC web-app config values (safe to expose). Enable the
# "Phone" and "Email link (passwordless)" sign-in providers in the Firebase
# console, and add your domain to Authentication → Settings → Authorized domains.
NEXT_PUBLIC_FIREBASE_API_KEY=""
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=""
NEXT_PUBLIC_FIREBASE_PROJECT_ID=""
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=""
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=""
NEXT_PUBLIC_FIREBASE_APP_ID=""
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=""

# Session signing secret (HMAC). Set a long random string in production.
AUTH_SESSION_SECRET=""
# Comma-separated admin emails/phones that receive the admin role on sign-in.
AUTH_ADMIN_EMAILS="admin@luxejewels.com"

# Auth (Clerk) — legacy/optional, no longer used by the OTP flow.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=""
CLERK_SECRET_KEY=""
CLERK_WEBHOOK_SECRET=""

# Payments — Stripe (international)
STRIPE_SECRET_KEY=""
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=""
STRIPE_WEBHOOK_SECRET=""

# Payments — Razorpay (India)
RAZORPAY_KEY_ID=""
RAZORPAY_KEY_SECRET=""
NEXT_PUBLIC_RAZORPAY_KEY_ID=""
RAZORPAY_WEBHOOK_SECRET=""

# Shipping — Shiprocket
SHIPROCKET_EMAIL=""
SHIPROCKET_PASSWORD=""
# Exact nickname from Shiprocket → Settings → Pickup Addresses. Required for the
# real order-create/AWB/label flow — without it, shipments fall back to mock.
SHIPROCKET_PICKUP_LOCATION=""
# Optional: token you configure in Shiprocket's webhook settings, checked against
# the x-api-key header on incoming webhook calls.
SHIPROCKET_WEBHOOK_TOKEN=""

# Reverse logistics — the warehouse/seller address returns are shipped BACK to.
# Used by the reverse-pickup flow (POST /orders/create/return). Falls back to the
# atelier address in lib/constants when unset.
WAREHOUSE_NAME="Shivis Elegance Warehouse"
WAREHOUSE_ADDRESS="The Atelier, 12 Marine Drive"
WAREHOUSE_CITY="Mumbai"
WAREHOUSE_STATE="Maharashtra"
WAREHOUSE_PINCODE="400020"
WAREHOUSE_PHONE=""
WAREHOUSE_EMAIL=""

# Encryption key for COD refund PII (bank/UPI) at rest — AES-256-GCM. Set a long
# random string in production (e.g. `openssl rand -base64 48`). If unset, the key
# is derived from AUTH_SESSION_SECRET so the flow still works with zero setup —
# but rotate/keep this stable or stored ciphertext becomes undecryptable.
ENCRYPTION_KEY=""

# Email — Resend (transactional order/return/cancel alerts). Optional: without
# RESEND_API_KEY emails are logged as stubs and never sent. Get a key at
# resend.com. Verify a sending domain, then set EMAIL_FROM to an address on it.
# ADMIN_EMAIL receives new-order and return alerts (defaults to the site email).
RESEND_API_KEY=""
EMAIL_FROM="Shivis Elegance <onboarding@resend.dev>"
ADMIN_EMAIL=""

# Media — Cloudinary
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""
CLOUDINARY_UPLOAD_PRESET=""
