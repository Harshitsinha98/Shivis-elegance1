// Shivis Elegance database schema
// Run: npx prisma generate && npx prisma db push
// Swap provider to "sqlite" + url "file:./dev.db" for a zero-setup local DB.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum Role {
  CUSTOMER
  ADMIN
}

enum OrderStatus {
  PENDING
  CONFIRMED
  PROCESSING
  SHIPPED
  OUT_FOR_DELIVERY
  DELIVERED
  CANCELLED
  RETURN_REQUESTED
  RETURNED
}

enum ReturnStatus {
  REQUESTED
  APPROVED
  REJECTED
  PICKUP_SCHEDULED
  PICKED_UP
  REFUND_INITIATED
  REFUND_COMPLETED
  COMPLETED
}

enum PaymentStatus {
  UNPAID
  PAID
  REFUNDED
  FAILED
}

model User {
  id          String    @id @default(cuid())
  clerkId     String?   @unique
  firebaseUid String?   @unique
  email       String    @unique
  name        String
  phone       String?
  role        Role      @default(CUSTOMER)
  avatarUrl   String?
  marketingOptIn Boolean @default(true)
  addresses   Address[]
  orders      Order[]
  reviews     Review[]
  wishlist    WishlistItem[]
  returnRequests ReturnRequest[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model Address {
  id         String  @id @default(cuid())
  user       User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId     String
  label      String
  fullName   String
  phone      String
  line1      String
  line2      String?
  city       String
  state      String
  postalCode String
  country    String  @default("India")
  isDefault  Boolean @default(false)
}

model Category {
  id       String    @id @default(cuid())
  slug     String    @unique
  name     String
  image    String?
  products Product[]
}

model Collection {
  id          String    @id @default(cuid())
  slug        String    @unique
  name        String
  description String
  heroImage   String?
  featured    Boolean   @default(false)
  products    Product[] @relation("ProductCollections")
}

model Product {
  id            String            @id @default(cuid())
  slug          String            @unique
  sku           String?           @unique
  name          String
  tagline       String
  description   String
  price         Int // paise
  compareAtPrice Int?
  currency      String            @default("INR")
  category      Category          @relation(fields: [categoryId], references: [id])
  categoryId    String
  collections   Collection[]      @relation("ProductCollections")
  metal         String
  gemstone      String
  purity        String
  weightGrams   Float
  images        String[]
  rating        Float             @default(0)
  reviewCount   Int               @default(0)
  stock         Int               @default(0)
  isNew         Boolean           @default(false)
  isBestSeller  Boolean           @default(false)
  tags          String[]
  variants      ProductVariant[]
  reviews       Review[]
  orderItems    OrderItem[]
  wishlistedBy  WishlistItem[]
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt
}

model ProductVariant {
  id         String  @id @default(cuid())
  product    Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  productId  String
  label      String
  value      String
  priceDelta Int     @default(0)
  stock      Int     @default(0)
}

model Order {
  id              String        @id @default(cuid())
  number          String        @unique
  user            User?         @relation(fields: [userId], references: [id])
  userId          String?
  email           String?
  phone           String?
  items           OrderItem[]
  subtotal        Int
  shipping        Int
  discount        Int           @default(0)
  tax             Int           @default(0)
  total           Int
  currency        String        @default("INR")
  status          OrderStatus   @default(PENDING)
  paymentStatus   PaymentStatus @default(UNPAID)
  paymentProvider String
  paymentRef      String?
  // Denormalised snapshot of the shipping address at time of order.
  shippingAddress Json
  trackingNumber  String?
  awb             String?
  courier         String?
  // Shiprocket's own shipment id (needed for pickup/label calls), its own
  // order id (needed for POST /orders/cancel), and the real courier-generated
  // label PDF url from POST /courier/generate/label.
  shipmentId        String?
  shiprocketOrderId String?
  labelUrl          String?
  shippedAt       DateTime?
  deliveredAt     DateTime?
  cancelledAt     DateTime?
  cancelReason    String?
  returnRequestedAt DateTime?
  returnedAt      DateTime?
  returnRequests  ReturnRequest[]
  couponCode      String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
}

model OrderItem {
  id           String   @id @default(cuid())
  order        Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  orderId      String
  product      Product? @relation(fields: [productId], references: [id])
  productId    String?
  slug         String
  name         String
  image        String
  variantLabel String?
  unitPrice    Int
  quantity     Int
  returnItems  ReturnItem[]
}

model ReturnRequest {
  id           String       @id @default(cuid())
  order        Order        @relation(fields: [orderId], references: [id], onDelete: Cascade)
  orderId      String
  user         User?        @relation(fields: [userId], references: [id])
  userId       String?
  status       ReturnStatus @default(REQUESTED)
  reason       String
  description  String?
  images       String[]
  adminNotes   String?
  refundAmount Int? // paise
  items        ReturnItem[]
  approvedAt   DateTime?
  rejectedAt   DateTime?
  refundedAt   DateTime?
  completedAt  DateTime?

  // ─────────────── Reverse logistics (Shiprocket reverse pickup) ───────────────
  // Shiprocket's own ids for the reverse shipment, plus courier/AWB/pickup data.
  reverseShipmentId     String?
  reverseOrderId        String?
  reverseAwb            String?
  reverseCourier        String?
  pickupId              String?
  pickupScheduledDate   DateTime?
  reverseLabelUrl       String?
  reverseManifestUrl    String?
  // Latest free-text courier status (e.g. "Out for pickup") + a normalised code
  // (see ReverseTrackingCode in the app). Kept as strings so new Shiprocket
  // statuses never require a migration.
  reverseTrackingStatus String?
  reverseTrackingCode   String?
  reverseTrackingUrl    String?
  estimatedPickupAt     DateTime?
  estimatedDeliveryAt   DateTime?
  // Append-only timeline of reverse-shipment + refund events (JSON array of
  // { code, label, at, note?, actor? }). Surfaced on both dashboards.
  timeline              Json?
  warehouseReceivedAt   DateTime?
  warehouseReceivedBy   String? // "webhook" | admin email | "system"

  // ─────────────────────────────── Refund ───────────────────────────────
  refundMethod          String? // "razorpay" | "upi" | "bank" | "cod_manual" | "original"
  refundStatus          String? // free-text lifecycle: awaiting_details | verification_pending | verified | processing | completed | failed | rejected
  refundId              String? // gateway refund id (rfnd_... for Razorpay)
  refundReference       String? // manual transaction reference for COD payouts
  refundProcessedAt     DateTime?
  refundAttempts        Int      @default(0)
  refundError           String?
  // Idempotency key — a unique constraint is the hard guarantee against
  // double-refunding the same return even under concurrent requests/webhooks.
  refundIdempotencyKey  String?  @unique

  // ───────────────── COD refund collection (encrypted PII) ─────────────────
  // Sensitive values are stored AES-256-GCM encrypted (see lib/security/crypto).
  upiIdEncrypted        String?
  bankAccountEncrypted  String? // encrypted JSON { accountNumber }
  ifscCode              String?
  bankHolderName        String?
  bankName              String?
  financeRemarks        String?
  financeReviewedAt     DateTime?
  financeReviewedBy     String?

  // ───────────────────────── Raw provider payloads ─────────────────────────
  shiprocketWebhookPayload Json?
  razorpayRefundPayload    Json?

  auditLogs    ReturnAuditLog[]

  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  @@index([reverseAwb])
  @@index([reverseShipmentId])
}

/// Append-only audit trail for every financial / logistics action on a return.
model ReturnAuditLog {
  id              String        @id @default(cuid())
  returnRequest   ReturnRequest @relation(fields: [returnRequestId], references: [id], onDelete: Cascade)
  returnRequestId String
  action          String // e.g. reverse_pickup_created | refund_initiated | cod_details_submitted
  actor           String? // "system" | "webhook" | admin email | customer id
  detail          String?
  metadata        Json?
  createdAt       DateTime      @default(now())

  @@index([returnRequestId])
}

/// Idempotency ledger for inbound webhooks. A unique (source,eventId) row means
/// a duplicate delivery is a no-op instead of a double state change.
model WebhookEvent {
  id        String   @id @default(cuid())
  source    String // "shiprocket" | "razorpay"
  eventId   String
  payload   Json?
  createdAt DateTime @default(now())

  @@unique([source, eventId])
}

model ReturnItem {
  id              String        @id @default(cuid())
  returnRequest   ReturnRequest @relation(fields: [returnRequestId], references: [id], onDelete: Cascade)
  returnRequestId String
  orderItem       OrderItem?    @relation(fields: [orderItemId], references: [id])
  orderItemId     String?
  // Snapshot so the return line survives even if the order item is removed.
  name            String
  image           String
  unitPrice       Int
  quantity        Int
}

model Review {
  id        String   @id @default(cuid())
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  productId String
  user      User?    @relation(fields: [userId], references: [id])
  userId    String?
  author    String
  rating    Int
  title     String
  body      String
  verified  Boolean  @default(false)
  approved  Boolean  @default(false)
  createdAt DateTime @default(now())
}

model WishlistItem {
  id        String  @id @default(cuid())
  user      User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  productId String

  @@unique([userId, productId])
}

model Coupon {
  id          String    @id @default(cuid())
  code        String    @unique
  description String
  type        String // "percentage" | "fixed"
  value       Int
  minSubtotal Int?
  active      Boolean   @default(true)
  expiresAt   DateTime?
  createdAt   DateTime  @default(now())
}
